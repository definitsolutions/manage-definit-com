# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/executive_email_review?schema=public"

# ── Microsoft Graph / Entra ID ────────────────────────────────
# Register an app in Azure Entra ID → App registrations.
# Platform: Web, Redirect URI: http://localhost:3000/api/auth/callback
# API permissions (delegated): Mail.Read, Mail.ReadWrite, User.Read
AZURE_CLIENT_ID="your-azure-app-client-id"
AZURE_CLIENT_SECRET="your-azure-app-client-secret"
AZURE_TENANT_ID="your-azure-tenant-id"

# ── OpenAI ────────────────────────────────────────────────────
OPENAI_API_KEY="sk-..."
OPENAI_MODEL="gpt-4o"

# ── Session ───────────────────────────────────────────────────
# 32+ character random string for encrypting session cookies
SESSION_SECRET="change-me-to-a-random-32-char-string!!"

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to "true" to use mock data instead of live Microsoft Graph / OpenAI.
# Useful for local development without Azure credentials.
MOCK_MODE="false"

# ── Sync defaults (override via config UI) ────────────────────
SYNC_DAYS="7"
STALE_HOURS="48"
UNREAD_HOURS="24"
