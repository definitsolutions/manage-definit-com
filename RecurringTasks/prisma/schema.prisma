generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -- Enums --

enum MembershipRole {
  member
  manager
  admin
}

enum Cadence {
  daily
  weekly
  monthly
  quarterly
  annual
}

enum TaskStatus {
  not_started
  in_progress
  blocked
  done
}

enum AuditEntityType {
  template
  task
}

enum AuditAction {
  create
  update
  delete
  complete
  reopen
}

// -- Models --

model User {
  id            String   @id @default(cuid())
  portalUserId  String   @unique
  email         String
  displayName   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships           DepartmentMembership[]
  ownedTaskInstances    TaskInstance[]         @relation("TaskOwner")
  backupTaskInstances   TaskInstance[]         @relation("TaskBackupOwner")
  defaultOwnedTemplates TaskTemplate[]         @relation("DefaultOwner")
  defaultBackupTemplates TaskTemplate[]        @relation("DefaultBackupOwner")
  createdTemplates      TaskTemplate[]         @relation("TemplateCreatedBy")
  updatedTemplates      TaskTemplate[]         @relation("TemplateUpdatedBy")
  createdTaskInstances  TaskInstance[]         @relation("TaskCreatedBy")
  updatedTaskInstances  TaskInstance[]         @relation("TaskUpdatedBy")
  auditLogs             AuditLog[]
}

model Department {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberships   DepartmentMembership[]
  taskTemplates TaskTemplate[]
  taskInstances TaskInstance[]
}

model DepartmentMembership {
  id           String         @id @default(cuid())
  userId       String
  departmentId String
  role         MembershipRole @default(member)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  department Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  @@unique([userId, departmentId])
  @@index([departmentId])
}

model TaskTemplate {
  id                   String   @id @default(cuid())
  departmentId         String
  title                String
  description          String?
  cadence              Cadence
  recurrenceRule       Json
  defaultOwnerId       String?
  defaultBackupOwnerId String?
  proofRequired        Boolean  @default(false)
  sopUrl               String?
  active               Boolean  @default(true)
  createdById          String
  updatedById          String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  department       Department     @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  defaultOwner     User?          @relation("DefaultOwner", fields: [defaultOwnerId], references: [id], onDelete: SetNull)
  defaultBackupOwner User?        @relation("DefaultBackupOwner", fields: [defaultBackupOwnerId], references: [id], onDelete: SetNull)
  createdBy        User           @relation("TemplateCreatedBy", fields: [createdById], references: [id])
  updatedBy        User           @relation("TemplateUpdatedBy", fields: [updatedById], references: [id])
  taskInstances    TaskInstance[]

  @@index([departmentId])
}

model TaskInstance {
  id                String      @id @default(cuid())
  templateId        String?
  departmentId      String
  title             String
  description       String?
  dueDate           DateTime
  cadence           Cadence?
  recurrenceRule    Json?
  ownerId           String?
  backupOwnerId     String?
  status            TaskStatus  @default(not_started)
  proofRequired     Boolean     @default(false)
  proofLink         String?
  completionNote    String?
  sopUrl            String?
  createdById       String
  updatedById       String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  completedAt       DateTime?

  template       TaskTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  department     Department    @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  owner          User?         @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  backupOwner    User?         @relation("TaskBackupOwner", fields: [backupOwnerId], references: [id], onDelete: SetNull)
  createdBy      User          @relation("TaskCreatedBy", fields: [createdById], references: [id])
  updatedBy      User          @relation("TaskUpdatedBy", fields: [updatedById], references: [id])

  @@unique([templateId, dueDate])
  @@index([departmentId])
  @@index([ownerId, status, dueDate])
}

model AuditLog {
  id            String          @id @default(cuid())
  entityType    AuditEntityType
  entityId      String
  action        AuditAction
  changedFields Json?
  actorUserId   String
  createdAt     DateTime        @default(now())

  actor User @relation(fields: [actorUserId], references: [id])

  @@index([entityType, entityId])
}
